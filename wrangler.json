{
  "main": ".open-next/worker.js",
  "name": "bonchona-radio",
  "compatibility_date": "2025-02-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "8a5fc6f211b3460ca4b413c9324c0fa3"
    }
  ],
  "r2_buckets": [
    {
      "binding": "PREROLL_BUCKET",
      "bucket_name": "bonchona-preroll"
    },
    {
      "binding": "IMAGES_BUCKET",
      "bucket_name": "bonchona-images"
    }
  ],
  "observability": {
    "enabled": true
  }
}
