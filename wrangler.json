{
  "main": ".open-next/worker.js",
  "name": "bonchona-radio",
  "compatibility_date": "2025-02-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "bonchona_kv_namespace"
    }
  ],
  "r2_buckets": [
    {
      "binding": "PREROLL_BUCKET",
      "bucket_name": "bonchona-preroll-bucket"
    }
  ],
  "observability": {
    "enabled": true
  }
}
